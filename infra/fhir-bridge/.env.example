# Copy to .env and adjust before: docker compose up -d

FHIR_BRIDGE_PORT=8888
FHIR_BRIDGE_IMAGE_TAG=latest

# EHRbase openEHR REST (trailing slash)
EHRBASE_BASE_URL=https://ehrbase.codemuseai.com/ehrbase/

# EHRbase auth: none | basic
EHRBASE_SECURITY_TYPE=none
EHRBASE_USER=
EHRBASE_PASSWORD=

# Admin FHIR Patient endpoint (must match Sentinel FHIR_BASE_URL patients)
ADMIN_FHIR_PATIENT_URL=https://term.codemuseai.com/fhir/Patient/
