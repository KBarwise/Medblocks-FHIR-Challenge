# ─── Codemuse product line (separate Vercel deploy) ───────────────────────────
# Administrative FHIR — Patient, Practitioner, Appointment, kiosk queues
FHIR_BASE_URL=https://term.codemuseai.com/fhir
FHIR_BEARER_TOKEN=

# Clinical chart — EHRbase FHIR R4 API (Observation, Condition, MedicationRequest, …)
CLINICAL_BACKEND=ehrbase
EHRBASE_FHIR_URL=https://ehrbase.codemuseai.com/ehrbase/rest/fhir/R4
EHRBASE_BEARER_TOKEN=

# Browser (must match server flags for trends proxy)
NEXT_PUBLIC_CLINICAL_BACKEND=ehrbase
NEXT_PUBLIC_CLINICAL_API_PREFIX=/api/clinical

# Product branding (optional)
NEXT_PUBLIC_PRODUCT_NAME=Sentinel
NEXT_PUBLIC_PRODUCT_VENDOR=Codemuse
NEXT_PUBLIC_PRODUCT_DESCRIPTION=Clinical workflow with EHRbase chart storage
NEXT_PUBLIC_DEFAULT_CLINIC_NAME=Demo Clinic

# Terminology — ECL $expand (Snowstorm)
TERMINOLOGY_ECL_BASE_URL=https://term.codemuseai.com/snowstorm
# Terminology — $validate-code, $lookup (often same host as admin FHIR)
TERMINOLOGY_BASE_URL=https://term.codemuseai.com/fhir
TERMINOLOGY_AUTH_HEADER=

# App
APP_ORIGIN=http://localhost:3000
NODE_ENV=development

# Legacy single-server mode (Lucea / HAPI only): set CLINICAL_BACKEND=fhir and use FHIR_BASE_URL for everything
